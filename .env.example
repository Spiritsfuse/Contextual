# Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini models to use
GEMINI_PRIMARY_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Top-k chunks to retrieve (default: 5)
TOP_K=5

# Chunk size in words (default: 200)
CHUNK_SIZE=200

# Chunk overlap in words (default: 30)
CHUNK_OVERLAP=30

# Backend URL for Streamlit (default: http://localhost:8000)
BACKEND_URL=http://localhost:8000

# Frontend URL for keep-alive script (default: http://localhost:8501)
FRONTEND_URL=http://localhost:8501

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
