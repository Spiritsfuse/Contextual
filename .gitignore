# .gitignore — PDF-Constrained Conversational Agent

# -----------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
# NOTE: .env.example is intentionally committed — it is a safe template

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw

# -----------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------
# FAISS index and local runtime data
# -----------------------------------------------------------------------
data/index/
*.faiss
*.pkl

# -----------------------------------------------------------------------
# Streamlit cache
# -----------------------------------------------------------------------
.streamlit/

# -----------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------
tmp/
*.tmp
*.bak

# -----------------------------------------------------------------------
# Demo script
# -----------------------------------------------------------------------
docs/demo_script.md
